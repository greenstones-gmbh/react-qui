{
  "name": "react-qui",
  "version": "1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "pub-local-core": "bun publish --cwd packages/qui-core --registry http://0.0.0.0:4873 --access public",
    "pub-local-bs": "bun publish --cwd packages/qui-bootstrap --registry http://0.0.0.0:4873 --access public",
    "pub-local-supabase": "bun publish --cwd packages/qui-supabase --registry http://0.0.0.0:4873 --access public",
    "pub-local": "bun run pub-local-core && bun run pub-local-bs && bun run pub-local-supabase",
    "pub-core-apha": "bun publish --cwd packages/qui-core --access public --tag alpha",
    "pub-bs-apha": "bun publish --cwd packages/qui-bootstrap --access public --tag alpha",
    "pub-supabase-apha": "bun publish --cwd packages/qui-supabase --access public --tag alpha",
    "pub-core": "bun publish --cwd packages/qui-core --access public",
    "pub-bs": "bun publish --cwd packages/qui-bootstrap --access public",
    "pub-supabase": "bun publish --cwd packages/qui-supabase --access public",
    "pub-ai": "bun publish --cwd packages/qui-ai --access public",
    "pub": "bun run pub-core && bun run pub-bs && bun run pub-supabase"
  },
  "author": "artem.grinstein@greenstones.de",
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.4.2",
    "@storybook/addon-interactions": "^8.4.2",
    "@storybook/addon-onboarding": "^8.4.2",
    "@storybook/blocks": "^8.4.2",
    "@storybook/react": "^8.4.2",
    "@storybook/react-vite": "^8.4.2",
    "@storybook/test": "^8.4.2",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prop-types": "^15.8.1",
    "storybook": "^8.4.2",
    "typescript-eslint": "^8.57.0"
  },
  "catalog": {
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "date-fns": "^4.1",
    "react-bootstrap": "^2.10",
    "classnames": "^2",
    "react-hook-form": "^7"
  }
}